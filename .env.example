# ──────────────────────────────────────────────────────────────────────────────
# SMART EMERGENCY ALERT SYSTEM (SEAS) - ENVIRONMENT VARIABLES TEMPLATE
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to a new file named '.env' and fill in your actual credentials.
# NEVER commit the actual '.env' file containing secrets to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database Connection (MySQL) ────────────────────────────────────────────────
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=mysql+pymysql://root:YOUR_DATABASE_PASSWORD@localhost:3306/smart_emergency

# ── Security & JWT Settings ───────────────────────────────────────────────────
# Tip: Generate a secure random key using 'openssl rand -hex 32'
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email/SMTP Configuration (For Live OTP) ──────────────────────────────────
# Set SMTP_PASSWORD to "console" to bypass live SMTP sending and print OTP to terminal.
# For production Gmail SMTP, enable 2-Step Verification and generate a 16-character App Password.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ── Admin & Notification Settings ─────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@gmail.com

# ── OTP Limits and Cooldowns ──────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
